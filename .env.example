# ==============================================================================
# Civitas Portal — Environment Variables Configuration
# ==============================================================================
# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in the required API keys
# 3. DO NOT commit .env.local to version control
# ==============================================================================

# [Required] Google Gemini API Key for AI features (Chat, OCR, Translation)
# Get a key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# [Required] Google Maps API Key for Polling Station Location Mapping
# Get a key at: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# [Optional] Firebase Configuration (If overriding default project config)
# VITE_FIREBASE_API_KEY=""
# VITE_FIREBASE_AUTH_DOMAIN=""
# VITE_FIREBASE_PROJECT_ID=""
# VITE_FIREBASE_STORAGE_BUCKET=""
# VITE_FIREBASE_MESSAGING_SENDER_ID=""
# VITE_FIREBASE_APP_ID=""
