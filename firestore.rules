rules_version = '2';

// Civitas Portal — Firestore Security Rules
// Principle of least privilege: deny all by default, allow only what's needed.

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Anonymized interactions — public read, unauthenticated append-only with strict validation
    match /anonymized_interactions/{docId} {
      // Allow reading (needed for getCountFromServer)
      allow read: if true;
      
      // Allow creation with strict validation to prevent abuse/injection
      allow create: if request.resource.data.keys().hasAll(['type', 'metadata', 'timestamp', 'sessionType'])
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 50
        && request.resource.data.sessionType == 'anonymous';
        
      // No updates or deletes allowed for append-only logs
      allow update, delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
